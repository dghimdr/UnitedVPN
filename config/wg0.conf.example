# Example only. The real file is generated at /etc/wireguard/wg0.conf.

[Interface]
Address = 10.8.0.1/24
ListenPort = 51820
PrivateKey = <server-private-key>
SaveConfig = false
PostUp = iptables -t nat -A POSTROUTING -s 10.8.0.0/24 -o <public-interface> -j MASQUERADE
PostDown = iptables -t nat -D POSTROUTING -s 10.8.0.0/24 -o <public-interface> -j MASQUERADE

# BEGIN_PEER example-user
[Peer]
# Name = example-user
# CreatedAt = 2026-06-17T00:00:00Z
PublicKey = <client-public-key>
AllowedIPs = 10.8.0.2/32
# END_PEER example-user
