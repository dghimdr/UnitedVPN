# Copy this file to config/vpn.env before running scripts/install-server.sh.
# The install script copies the final configuration to /etc/wireguard/vpn.env.

# Public endpoint clients will connect to.
# Use either SERVER_PUBLIC_IP or SERVER_DNS_NAME.
SERVER_PUBLIC_IP="203.0.113.10"
SERVER_DNS_NAME=""

# Singapore VPS public network interface.
# Leave empty to auto-detect from the default route.
PUBLIC_INTERFACE=""

# WireGuard server settings.
WG_INTERFACE="wg0"
WG_PORT="51820"
VPN_CIDR="10.8.0.0/24"
SERVER_VPN_IP="10.8.0.1/24"
SERVER_VPN_IP_SHORT="10.8.0.1"
CLIENT_DNS="1.1.1.1, 1.0.0.1"
CLIENT_ALLOWED_IPS="0.0.0.0/0"
CLIENT_PERSISTENT_KEEPALIVE="25"

# User allocation.
CLIENT_IP_START="2"
CLIENT_IP_END="21"
MAX_USERS="20"

# Firewall settings.
SSH_PORT="22"

# Safety override for installs run from a recovery console or provider web console.
# Leave disabled for normal SSH installs.
ALLOW_SSH_PORT_MISMATCH="0"

# Operational paths. Change only if you know why.
WG_DIR="/etc/wireguard"
CLIENTS_DIR="/etc/wireguard/clients"
STATE_FILE="/etc/wireguard/clients/peers.tsv"
BACKUP_DIR="/root/wireguard-backups"
