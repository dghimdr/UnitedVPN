# Copy this file to /etc/wireguard/uk.env on vpn-uk-london-1.
# This config is for client provisioning only. It does not install or modify UFW.

# Public endpoint UK clients will connect to.
SERVER_PUBLIC_IP="45.63.96.40"
SERVER_DNS_NAME=""

# UK WireGuard server public key. Never put the server private key here.
SERVER_PUBLIC_KEY="pcW+Re55jzLJamMiq96RUCQndFLGA3pSEylPQY96GSo="

# WireGuard server settings already confirmed on vpn-uk-london-1.
WG_INTERFACE="wg0"
WG_PORT="51820"
VPN_CIDR="10.9.0.0/24"
SERVER_VPN_IP="10.9.0.1/24"
SERVER_VPN_IP_SHORT="10.9.0.1"
CLIENT_DNS="1.1.1.1, 1.0.0.1"
CLIENT_ALLOWED_IPS="0.0.0.0/0"
CLIENT_PERSISTENT_KEEPALIVE="25"

# UK user allocation.
# 10.9.0.2 is reserved for the manual David test client.
CLIENT_IP_START="3"
CLIENT_IP_END="22"
MAX_USERS="20"

# Operational paths for UK-generated client assets.
WG_DIR="/etc/wireguard"
CLIENTS_DIR="/etc/wireguard/clients-uk"
STATE_FILE="/etc/wireguard/clients-uk/peers.tsv"
BACKUP_DIR="/root/wireguard-backups"
